{
  "name": "@promptfence/sdk",
  "version": "0.1.0",
  "description": "PromptFence SDK — PII scanning for AI applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "node --test src/__tests__/*.test.js"
  },
  "keywords": ["ai", "pii", "privacy", "promptfence", "llm", "openai", "gdpr"],
  "author": "PromptFence",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
