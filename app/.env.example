# ── Required ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-secret-here-min-32-chars

# Path to SQLite DB — set this to your Railway Volume mount path
# Railway: add a Volume mounted at /data, then set this to /data/promptfence.db
DATABASE_PATH=/data/promptfence.db

# Your app's public URL (no trailing slash)
BASE_URL=https://app.promptfence.ai

# ── Email (Resend) ────────────────────────────────────────────────
# Get from resend.com — add promptfence.ai as a sending domain first
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Paddle Billing ───────────────────────────────────────────────
# Get from paddle.com → Developer Tools → Authentication
# Use sandbox keys for testing: sandbox.paddle.com
#
# Secret API key (server-side only)
PADDLE_API_KEY=pdl_live_xxxxxxxxxxxx
#
# Webhook secret — from Paddle → Notifications → your endpoint
PADDLE_WEBHOOK_SECRET=pdl_ntfset_xxxxxxxxxxxx
#
# Client-side token (safe to expose — NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxxxxxxxxxx
#
# Price IDs from Paddle → Catalog → Prices
PADDLE_TEAM_PRICE_ID=pri_xxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_TEAM_PRICE_ID=pri_xxxxxxxxxxxx
PADDLE_BUSINESS_PRICE_ID=pri_xxxxxxxxxxxx
NEXT_PUBLIC_PADDLE_BUSINESS_PRICE_ID=pri_xxxxxxxxxxxx

# ── Super Admin (seed account — never changes after first deploy) ─
# Set these ONCE before first deploy. Used by: node scripts/seed.js
SUPER_ADMIN_EMAIL=your-personal-email@gmail.com
SUPER_ADMIN_PASSWORD=changeme-set-a-strong-password

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
