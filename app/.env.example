# ── Required ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=your-secret-here-min-32-chars

# Path to SQLite DB — set this to your Railway Volume mount path
# Railway: add a Volume mounted at /data, then set this to /data/promptfence.db
DATABASE_PATH=/data/promptfence.db

# Your app's public URL (no trailing slash)
BASE_URL=https://app.promptfence.ai

# ── Email (Resend) ────────────────────────────────────────────────
# Get from resend.com — add promptfence.ai as a sending domain first
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Paddle Billing ───────────────────────────────────────────────
# Get from paddle.com dashboard (use sandbox keys for testing)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_TEAM_PRICE_MONTHLY=
PADDLE_TEAM_PRICE_ANNUAL=
PADDLE_BUSINESS_PRICE_MONTHLY=
PADDLE_BUSINESS_PRICE_ANNUAL=

# ── Super Admin (seed account — never changes after first deploy) ─
# Set these ONCE before first deploy. Used by the seed script.
SUPER_ADMIN_EMAIL=your-personal-email@gmail.com
SUPER_ADMIN_PASSWORD=changeme-set-a-strong-password

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
