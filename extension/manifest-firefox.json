{
  "manifest_version": 3,
  "name": "PromptFence",
  "version": "1.1.0",
  "description": "Prevents accidental sharing of sensitive data in AI chats. Detects emails, phones, IBANs, cards, and more. Runs locally.",
  "browser_specific_settings": {
    "gecko": {
      "id": "promptfence@promptfence.ai",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.mistral.ai/*",
    "https://app.slack.com/*",
    "https://mail.google.com/*",
    "https://notion.so/*",
    "https://www.notion.so/*",
    "https://linear.app/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://app.promptfence.ai/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://app.slack.com/*",
        "https://mail.google.com/*",
        "https://notion.so/*",
        "https://www.notion.so/*",
        "https://linear.app/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*"
      ],
      "js": ["rules.js", "src/logic.js", "content.js"],
      "css": ["ui.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["service_worker.js"]
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "welcome.html",
    "default_title": "PromptFence"
  }
}
